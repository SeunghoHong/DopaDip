{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mise:*)",
      "Bash(tuist:*)",
      "Bash(xcodebuild:*)",
      "Bash(xcrun:*)",
      "Bash(xcrun simctl:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tuist-regenerate.sh"
          }
        ]
      }
    ]
  }
}
